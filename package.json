{
  "name": "cuneiform-mcp",
  "version": "0.65.0",
  "description": "MCP server exposing CDLI, ORACC, OGSL, and eBL/Fragmentarium cuneiform corpora to LLM agents.",
  "type": "module",
  "bin": {
    "cuneiform-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "smoke": "node dist/index.js --smoke",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "schemas",
    "data",
    "README.md",
    "PROTOCOL.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "5.7.2",
    "vitest": "^4.1.7"
  },
  "license": "MIT"
}
