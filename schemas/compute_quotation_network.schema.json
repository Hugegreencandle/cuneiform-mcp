{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danebrown/cuneiform-mcp/schemas/compute_quotation_network.schema.json",
  "title": "compute_quotation_network data payload",
  "description": "v0.68.0 corpus-wide directed quotation graph at the composition level. Aggregates citation-network (v0.43) commentary→base edges with chunk-parallel (v0.19) cross-composition shared-chunk hosts; both streams contribute to a single multigraph where evidence_type flags which streams supported a given edge. Composition IDs are resolved via the v0.37 composition registry, the v0.54 composition-assignments cache, and v0.32 identifyComposition (fallback). Outputs are written to ~/.cache/cuneiform-mcp/quotation-network/<iso-ts>/graph.{json,dot} + summary.md.",
  "type": "object",
  "required": ["nodes", "edges", "metrics", "output_paths", "warnings"],
  "additionalProperties": false,
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["composition_id", "display_name", "in_degree", "out_degree", "betweenness_rank"],
        "additionalProperties": false,
        "properties": {
          "composition_id": { "type": "string", "description": "Registry composition id (e.g. mis_pi, surpu, maqlu)." },
          "display_name": { "type": "string", "description": "Human-readable composition name (e.g. 'Mīs pî')." },
          "in_degree": { "type": "integer", "minimum": 0 },
          "out_degree": { "type": "integer", "minimum": 0 },
          "betweenness_rank": {
            "type": ["integer", "null"],
            "minimum": 1,
            "description": "Approximate sampled-source betweenness rank (1 = highest). Null when node never sits on an intermediate position."
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_composition", "target_composition", "evidence_type", "weight", "supporting_tablets"],
        "additionalProperties": false,
        "properties": {
          "source_composition": { "type": "string" },
          "target_composition": { "type": "string" },
          "evidence_type": { "enum": ["citation", "chunk_parallel", "both"] },
          "weight": { "type": "number", "minimum": 0 },
          "supporting_tablets": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 5,
            "description": "Up to 5 sample tablet ids that contributed to this edge."
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "total_nodes",
        "total_edges",
        "top_quoted_from",
        "top_quoters",
        "isolate_compositions",
        "scc_count",
        "scc_largest_size"
      ],
      "additionalProperties": false,
      "properties": {
        "total_nodes": { "type": "integer", "minimum": 0 },
        "total_edges": { "type": "integer", "minimum": 0 },
        "top_quoted_from": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["composition", "in_degree"],
            "additionalProperties": false,
            "properties": {
              "composition": { "type": "string" },
              "in_degree": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "top_quoters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["composition", "out_degree"],
            "additionalProperties": false,
            "properties": {
              "composition": { "type": "string" },
              "out_degree": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "isolate_compositions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scc_count": { "type": "integer", "minimum": 0 },
        "scc_largest_size": { "type": "integer", "minimum": 0 },
        "directed_chunk_pairs": { "type": "integer", "minimum": 0 },
        "symmetric_chunk_pairs": { "type": "integer", "minimum": 0 },
        "directed_edge_fraction": { "type": "number", "minimum": 0 },
        "edges_pruned_below_threshold": { "type": "integer", "minimum": 0 },
        "recommended_min_edge_weight": { "type": "number", "minimum": 0 },
        "hub_fanout_threshold": { "type": "number", "minimum": 0 },
        "hub_tablets_demoted": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tablet_id", "chunk_fanout"],
            "additionalProperties": false,
            "properties": {
              "tablet_id": { "type": "string" },
              "chunk_fanout": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "weight_demoted_by_hub_guard": { "type": "number", "minimum": 0 }
      }
    },
    "output_paths": {
      "type": "object",
      "required": ["json", "dot", "summary_md"],
      "additionalProperties": false,
      "properties": {
        "json": { "type": "string" },
        "dot": { "type": "string" },
        "summary_md": { "type": "string" }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
