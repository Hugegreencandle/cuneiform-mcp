{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danebrown/cuneiform-mcp/schemas/find_bilingual_tablets.schema.json",
  "title": "find_bilingual_tablets data payload",
  "description": "v0.66.0 — cache-backed corpus-wide bilingual surface. Reads ~/.cache/cuneiform-mcp/bilingual-index.json (built by scripts/build-bilingual-index.mjs) and returns ranked bilingual candidates by composite confidence (threshold-gap + token-share balance). Returns empty tablets + warning when the cache is missing.",
  "type": "object",
  "required": ["query", "tablets", "cache_stats", "warnings"],
  "additionalProperties": false,
  "properties": {
    "query": {
      "type": "object",
      "required": ["top_k", "classification_filter", "min_confidence"],
      "additionalProperties": false,
      "properties": {
        "top_k": { "type": "integer", "minimum": 1 },
        "classification_filter": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "min_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "tablets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "tablet_id",
          "classification",
          "genre_path",
          "text_line_count",
          "sumerian_token_share",
          "akkadian_token_share",
          "alternation_pattern",
          "confidence"
        ],
        "additionalProperties": false,
        "properties": {
          "tablet_id": { "type": "string" },
          "classification": { "type": "string" },
          "genre_path": { "type": ["string", "null"] },
          "text_line_count": { "type": "integer", "minimum": 0 },
          "sumerian_token_share": { "type": "number", "minimum": 0, "maximum": 1 },
          "akkadian_token_share": { "type": "number", "minimum": 0, "maximum": 1 },
          "alternation_pattern": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "cache_stats": {
      "type": "object",
      "required": [
        "cache_path",
        "cache_exists",
        "cache_built_at",
        "tablets_in_cache",
        "tablets_classified_bilingual"
      ],
      "additionalProperties": false,
      "properties": {
        "cache_path": { "type": "string" },
        "cache_exists": { "type": "boolean" },
        "cache_built_at": { "type": ["string", "null"] },
        "tablets_in_cache": { "type": "integer", "minimum": 0 },
        "tablets_classified_bilingual": { "type": "integer", "minimum": 0 }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
