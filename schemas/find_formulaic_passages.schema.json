{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danebrown/cuneiform-mcp/schemas/find_formulaic_passages.schema.json",
  "title": "find_formulaic_passages data payload",
  "description": "v0.20.0 corpus-wide formulaic-passage discovery. Surfaces every length-20 trigram window shared with at least min_hosts tablets, ranked by host_genres_spanned × log(host_count). Backed by the chunk-hash index (~/.cache/cuneiform-mcp/chunk-index.json); built once via scripts/build-chunk-index.mjs. Cross-curricular passages outrank colophon templates by design.",
  "type": "object",
  "required": ["passages", "index_stats", "warnings"],
  "additionalProperties": false,
  "properties": {
    "passages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chunk_hash",
          "chunk_signs",
          "chunk_length",
          "host_count",
          "host_genres_spanned",
          "host_periods_spanned",
          "host_tablets",
          "novelty_score"
        ],
        "additionalProperties": false,
        "properties": {
          "chunk_hash": { "type": "string", "description": "Canonical pipe-joined trigram window hash (length 20)." },
          "chunk_signs": { "type": "string", "description": "Reconstructed sign sequence with '…' for X-skip gaps." },
          "chunk_length": { "type": "integer", "minimum": 1 },
          "host_count": { "type": "integer", "minimum": 2 },
          "host_genres_spanned": { "type": "integer", "minimum": 0 },
          "host_periods_spanned": { "type": "integer", "minimum": 0 },
          "host_tablets": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tablet_id", "period", "genre"],
              "additionalProperties": false,
              "properties": {
                "tablet_id": { "type": "string" },
                "period": { "type": ["string", "null"] },
                "genre": { "type": ["string", "null"] }
              }
            },
            "description": "Up to 20 hosts inline; query the chunk-hash index directly for the full set."
          },
          "novelty_score": { "type": "number", "minimum": 0 }
        }
      }
    },
    "index_stats": {
      "type": "object",
      "required": [
        "loaded",
        "total_chunks_in_index",
        "candidates_above_threshold",
        "after_filters",
        "metadata_coverage_pct"
      ],
      "additionalProperties": false,
      "properties": {
        "loaded": { "type": "boolean" },
        "total_chunks_in_index": { "type": "integer", "minimum": 0 },
        "candidates_above_threshold": { "type": "integer", "minimum": 0 },
        "after_filters": { "type": "integer", "minimum": 0 },
        "metadata_coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
